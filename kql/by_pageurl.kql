// Views for PageURLs matching a pattern (LIKE-style).
// KQL has no LIKE operator; `contains` is case-insensitive substring match
// and behaves like SQL `LIKE '%pattern%'`. Use `matches regex` for full regex.

let TargetUrlPattern = "sitepages/home";   // substring, case-insensitive
let StartTime = datetime(2026-03-01);
let EndTime   = datetime(2026-04-01);

pageViews
| where timestamp between (StartTime .. EndTime)
// Top-level URL filter first (indexed, fast):
| where url contains TargetUrlPattern
| extend cp = parse_json(tostring(parse_json(tostring(customDimensions)).CustomProps))
// Optionally also match the business URL:
//| where tostring(cp.PageURL) contains TargetUrlPattern
| project
    timestamp,
    view_id          = id,
    session_Id,
    user_Id,
    duration_ms      = duration,
    client_OS, client_Browser, client_CountryOrRegion,
    PageId           = tostring(cp.PageId),
    PageName         = tostring(cp.PageName),
    SiteName         = tostring(cp.SiteName),
    CammsTrackingID  = tostring(cp.CammsTrackingID),
    ContentOwner     = tostring(cp.ContentOwner),
    PublishingDate   = tostring(cp.PublishingDate),
    refUri           = tostring(cp.refUri)
| order by timestamp desc

// ---------------------------------------------------------------------------
// Summary: total Views and Unique Visitors for the same URL pattern + window.
// Views          = row count in pageViews (each row = one page view event).
// UniqueVisitors = distinct user_Id (dcount is approximate; use dcountif/
//                  count_distinct for exact if needed).
// ---------------------------------------------------------------------------
pageViews
| where timestamp between (StartTime .. EndTime)
| where url contains TargetUrlPattern
| summarize
    Views          = count(),
    UniqueVisitors = dcount(user_Id),
    UniqueSessions = dcount(session_Id),
    FirstSeen      = min(timestamp),
    LastSeen       = max(timestamp)

// ---------------------------------------------------------------------------
// Breakout: Views and Unique Visitors per PageURL.
// Groups by the raw top-level `url` (indexed) — swap for cp.PageURL / cp.PageName
// if you want the business URL / page title instead.
// ---------------------------------------------------------------------------
pageViews
| where timestamp between (StartTime .. EndTime)
| where url contains TargetUrlPattern
| summarize
    Views          = count(),
    UniqueVisitors = dcount(user_Id),
    UniqueSessions = dcount(session_Id),
    FirstSeen      = min(timestamp),
    LastSeen       = max(timestamp)
    by url
| order by Views desc
