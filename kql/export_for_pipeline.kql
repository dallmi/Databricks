// EXPORT query for flatten_appinsights.py
// Returns customDimensions as an unmodified JSON string so the Python
// pipeline can apply its own flatten logic.
//
// Procedure:
// 1. Adjust the time window (max ~30 days / 65k rows per export run).
// 2. In the Azure Portal click "Export -> CSV (all columns)".
// 3. Drop the CSV into Databricks/input/.
// 4. Run: python scripts/flatten_appinsights.py

let StartTime = datetime(2026-03-01);
let EndTime   = datetime(2026-04-01);

pageViews
| where timestamp between (StartTime .. EndTime)
| project
    timestamp,
    id,
    name,
    url,
    duration,
    performanceBucket,
    itemType,
    customDimensions,         // <-- keep as JSON string
    operation_Name,
    operation_Id,
    operation_ParentId,
    session_Id,
    user_Id,
    client_Type,
    client_Model,
    client_OS,
    client_IP,
    client_City,
    client_StateOrProvince,
    client_CountryOrRegion,
    client_Browser,
    appId,
    iKey,
    sdkVersion,
    itemCount
| order by timestamp asc
